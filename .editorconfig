# EditorConfig helps maintain consistent coding styles for multiple developers
# https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space

# JS/TS files
[*.{js,jsx,ts,tsx,json}]
indent_size = 2

# Python files
[*.py]
indent_size = 4
max_line_length = 100

# Markdown
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2
