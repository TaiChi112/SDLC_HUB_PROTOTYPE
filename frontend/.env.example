GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL Database Configuration (for Docker Compose)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Database
DATABASE_URL=""

# PostgreSQL Admin (pgAdmin)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# For SQLite (development)
# DATABASE_URL="file:./dev.db"
# ============================================
# Auth.js / NextAuth.js Configuration
# ============================================

# Auth.js Secret - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"

# Auth.js URL - Not needed in production on Vercel
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# OAuth Provider Credentials
# ============================================

# GitHub OAuth
# Get these from: https://github.com/settings/developers
# 1. Go to Settings > Developer settings > OAuth apps > New OAuth App
# 2. Set Authorization callback URL to: http://localhost:3000/api/auth/callback/github
GITHUB_ID="your_github_client_id"
GITHUB_SECRET="your_github_client_secret"

# Google OAuth
# Get these from: https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_ID="your_google_client_id"
GOOGLE_SECRET="your_google_client_secret"
